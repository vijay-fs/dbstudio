{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bearhold Studio",
  "version": "0.0.1",
  "identifier": "studio.bearhold.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @dbstudio/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @dbstudio/web build:desktop",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bearhold Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis", "app"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Cross-platform database management studio",
    "longDescription": "Connect to PostgreSQL, MySQL, MongoDB, Redis, and more. SQL editor, result grid, and visual ER diagrams.",
    "copyright": "Copyright (c) 2026 Bearhold Studio contributors",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [],
      "dialog": false
    }
  }
}
